'''
Ask the user how many numbers they want to enter.  
2. Take that many numbers as input from the user, one by one.  
3. Store the numbers in a list.  
4. Use a FOR LOOP and IF conditions to create three lists:
   - positive_numbers
   - negative_numbers
   - zeros
5. Print all three lists at the end.'''

positive_numbers = []
negative_numbers = []
zero = []
user_range = int(input("How many numbers you need to enter:"))
for i in range(user_range):
    values = int(input("enter positive/negative/zero values :"))
    if values >0: 
        positive_numbers.append(values)
    elif values <0:
        negative_numbers.append(values)
    else:
            zero.append(values)

print(positive_numbers)
print(negative_numbers)
